<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lab Assignment: Forms and Tables</title>
    <style>
        table,
        th,
        td {
            border: 1px solid black;
            border-collapse: collapse;
            padding: 8px;
        }

        th {
            background-color: #f2f2f2;
        }

        .form-row {
            display: grid;
            grid-template-columns: 150px 1fr;
            align-items: center;
            margin-bottom: 10px;

        }

        .form-row label {
            text-align: left;
            padding-right: 10px;
        }

        .form-row input,
        .form-row div {
            justify-self: end;
        }

        .form-container {
            background-color: #f9f9f9;
            border-radius: 10px;
            margin: 20px auto;
            width: 88%;
        }

        .table-container {
            margin: 20px auto;
            width: 88%;

        }

        .body-container {
            background-color: #f9f9f9;
            width: 60%;
            margin: 0 auto;
        }
    </style>
</head>

<body>
    <div class="body-container">
        <h1>Student Registration Form</h1>

 
        <form action="/addStudent" method="POST">
            <fieldset class="form-container">
                <div class="form-row">
                    <label for="name">Name:</label>
                    <input type="text" name="name" id="name" placeholder="Alex Johnson" required>
                </div>

                <div class="form-row">
                    <label for="email">Email:</label>
                    <input type="email" name="email" id="email" placeholder="alex.johnson@example.com" required>
                </div>

                <div class="form-row">
                    <label for="password">Password:</label>
                    <input type="password" name="password" id="password" placeholder="**********************************" required>
                </div>

                <div class="form-row">
                    <label for="gender">Gender:</label>
                    <div>
                        <input type="radio" id="gender-male" name="gender" value="Male"> Male
                        <input type="radio" id="gender-female" name="gender" value="Female"> Female
                        <input type="radio" id="gender-other" name="gender" value="Other"> Other
                    </div>
                </div>

                <div class="form-row">
                    <label for="dob">Date of Birth:</label>
                    <input type="date" name="dateOfBirth" id="dateOfBirth" required>
                </div>

                <div class="form-row">
                    <input type="submit" value="Submit">
                </div>

            </fieldset>
        </form>

        <br>
        <hr>
        <br>

        <h2>Student Data</h2>
        <table class="table-container" id="dataTable">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Gender</th>
                    <th>Date of Birth</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(user => { %>
                    <tr>
                        <td><%= user.name %></td>
                        <td><%= user.email %></td>
                        <td><%= user.gender %></td>
                        <td><%= user.dateOfBirth %></td>
                        <td>
                            <form action="/delete/<%= user._id %>" method="POST" style="display:inline;">
                                <button type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

</body>

</html>